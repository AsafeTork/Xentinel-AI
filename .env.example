FLASK_ENV=production
SECRET_KEY=change-me
APP_LANG=en

# Branding / domain (visible)
APP_NAME="NewName"
BASE_URL="https://newdomain.com"

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/nexus

# Redis / RQ
REDIS_URL=redis://redis:6379/0

# LLM timeouts (opcional) - evita travar por muito tempo em provider instável
LLM_TIMEOUT_S=180

# LLM cache (opcional) - reduz custos e chamadas repetidas
LLM_CACHE_TTL_S=604800

# RQ job controls (opcional) - ambientes pequenos
AUDIT_JOB_TIMEOUT_S=1800
AUDIT_JOB_TTL_S=3600
UI_JOB_TIMEOUT_S=1800
UI_JOB_TTL_S=1800

# UI Lab (opcional) - limites de contexto (evita falhas do LLM por excesso de texto)
UI_LAB_MAX_CHARS_EACH=12000
UI_LAB_MAX_CONTEXT_CHARS=180000
UI_LAB_MAX_SITE_HTML_CHARS=12000

# Backend Lab (opcional) - limites de contexto
BACKEND_LAB_MAX_CHARS_EACH=12000
BACKEND_LAB_MAX_CONTEXT_CHARS=220000

# Admin Console (/admin/logs) - limites (aumente se quiser "ver tudo")
ADMIN_LOGS_AUDITS_LIMIT=300
ADMIN_LOGS_EVENTS_LIMIT=2500
ADMIN_LOGS_ERROR_EVENTS_LIMIT=5000
ADMIN_LOGS_RUNS_LIMIT=50
ADMIN_LOGS_RUN_TAIL_CHARS=6000
ADMIN_LOGS_MAX_ERROR_RUN_TAILS=12

# LLM fallback (org-level settings in /admin can override these)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL_V1=https://eclipse.mestredoblack.pro/v1
LLM_API_KEY=mc_live_SUA_CHAVE_AQUI
LLM_DEFAULT_MODEL=deepseek-chat
LLM_MODELS_CACHE_TTL_S=60
# Requisições non-stream: número de tentativas em caso de JSON inválido/502/524.
LLM_NONSTREAM_RETRIES=4
# Opcional: lista custom/allowlist de modelos (CSV ou 1 por linha)
LLM_MODELS_ALLOWLIST=

# Admin global (opcional)
# Se 1, qualquer usuário com role=admin consegue ver/gerenciar TODOS os usuários/orgs.
# Se 0, só o MASTER_ADMIN_EMAIL tem visão global.
ADMIN_GLOBAL_USERS=0

# Continuous monitoring (cron)
# Configure a Render cron job to call:
#   POST https://<your-domain>/admin/monitor/tick?token=...
MONITOR_TICK_TOKEN=

# Decision engine (value layer)
DECISION_TOP_N=3
MONITOR_DECISION_LOOKBACK=10

# Verification loop (action feedback)
# (No extra config required; stored deterministically via monitoring_findings.)

# Adaptive learning (no external APIs)
# LearningStat is updated after each run and affects confidence + small score adjustment.
LEARNING_ENABLED=1

# Safety & policy (defaults)
POLICY_DEFAULT_MAX_RISK_LEVEL=HIGH
POLICY_DEFAULT_MAX_RATE_RPS=20

# Context engine
CONTEXT_LOOKBACK=20

# Audit brief (opcional) - posicionamento/objetivo do produto para guiar a auditoria e melhorar qualidade
# Dica: cole um texto curto (até ~8k chars). Não é segredo.
AUDIT_BRIEF=

# Audit reflection (opcional) - 2 passagens por camada (draft + revisão) para aumentar qualidade.
# Nota: aumenta custo/tempo de auditoria.
AUDIT_REFLECT=0

# Attack total estimation (opcional)
# - security: soma apenas categorias de segurança/infra
# - all: soma qualquer linha que tiver USD parseável
AUDIT_ATTACK_TOTAL_MODE=security

# Resiliência do provedor LLM (opcional)
# Quantas falhas consecutivas do LLM antes de abortar a auditoria.
AUDIT_MAX_CONSECUTIVE_LLM_FAILURES=4

# Pesquisa de mercado (CatchAll / Newscatcher) - opcional
# OBS: este módulo é assíncrono e usa cache; pode demorar para aparecer na 1ª auditoria.
AUDIT_MARKET_RESEARCH=0
CATCHALL_API_KEY=
AUDIT_MARKET_DAYS=30
AUDIT_MARKET_MODE=lite
AUDIT_MARKET_LIMIT=10
AUDIT_MARKET_POLL_MAX_S=45
AUDIT_MARKET_POLL_INTERVAL_S=6
AUDIT_MARKET_CACHE_TTL_S=604800
# Você pode customizar o query/context:
AUDIT_MARKET_QUERY=average cost of data breach ransomware incident downtime cost per hour cyber attack losses
AUDIT_MARKET_CONTEXT=Extract USD costs, ranges, and what the estimate refers to (breach, ransomware, downtime, phishing).

# Dashboard cache (opcional) - segundos
DASH_CACHE_TTL_S=60

# Master admin (único que pode conceder admin)
MASTER_ADMIN_EMAIL=asafetork@gmail.com

# OAuth (opcional)
OAUTH_GOOGLE_CLIENT_ID=980496024382-v09mc5ebhl15f3baqf8pfb07q4kdbsq1.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=Ov23liyLkysk4djlrs4B
OAUTH_GITHUB_CLIENT_SECRET=

# GitHub (opcional) - publicar auditorias como Issue
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
